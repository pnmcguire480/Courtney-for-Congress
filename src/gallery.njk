pageStyle: >
  /* FILTER BAR */
  .filter-bar{background:var(--white);border-bottom:1px solid var(--cream-dark);padding:1rem 1.5rem;position:sticky;top:62px;z-index:100}
  .filter-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap}
  .filter-label{font-family:'Bebas Neue',sans-serif;font-size:0.75rem;letter-spacing:0.2em;color:var(--text-light);text-transform:uppercase;margin-right:0.25rem}
  .filter-btn{padding:0.4rem 1rem;border-radius:50px;border:1.5px solid var(--cream-dark);background:transparent;color:var(--text-light);font-size:0.82rem;font-weight:600;cursor:pointer;transition:all 0.2s;font-family:'Source Sans 3',sans-serif;min-height:44px}
  .filter-btn:hover,.filter-btn.active{background:var(--plum);color:var(--white);border-color:var(--plum)}
  /* GALLERY */
  .section-inner{max-width:1200px}
  .photo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin-top:2rem}
  .photo-item{position:relative;border-radius:12px;overflow:hidden;cursor:pointer;background:var(--cream-dark);aspect-ratio:4/3}
  .photo-item.tall{aspect-ratio:3/4}
  .photo-item.wide{grid-column:span 2}
  .photo-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.4s ease}
  .photo-item:hover img{transform:scale(1.04)}
  .photo-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(42,14,58,0.75) 0%,transparent 55%);opacity:0;transition:opacity 0.3s ease;display:flex;align-items:flex-end;padding:1.25rem}
  .photo-item:hover .photo-overlay{opacity:1}
  .photo-caption-hover{color:var(--white);font-size:0.85rem;font-weight:600;line-height:1.3}
  .photo-caption-hover span{display:block;font-size:0.75rem;color:var(--coral-light);font-family:'Bebas Neue',sans-serif;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.2rem}
  .photo-placeholder{background:linear-gradient(135deg,var(--cream-dark),var(--cream));display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.5rem;min-height:200px;border:2px dashed rgba(0,0,0,0.1)}
  .photo-placeholder-icon{font-size:2.5rem;opacity:0.3}
  .photo-placeholder-text{font-size:0.78rem;color:var(--text-light);text-align:center;font-style:italic}
  /* LIGHTBOX */
  .lightbox{display:none;position:fixed;inset:0;z-index:2000;background:rgba(10,4,18,0.95);align-items:center;justify-content:center;padding:1.5rem}
  .lightbox.open{display:flex}
  .lightbox-inner{position:relative;max-width:960px;width:100%;max-height:90vh;display:flex;flex-direction:column;align-items:center}
  .lightbox-img{max-width:100%;max-height:75vh;object-fit:contain;border-radius:8px;box-shadow:0 20px 80px rgba(0,0,0,0.5)}
  .lightbox-caption{margin-top:1.25rem;text-align:center;color:rgba(255,255,255,0.8);font-size:0.9rem;line-height:1.5;max-width:640px}
  .lightbox-caption strong{display:block;color:var(--coral-light);font-family:'Bebas Neue',sans-serif;letter-spacing:0.15em;font-size:0.78rem;margin-bottom:0.2rem;text-transform:uppercase}
  .lightbox-close{position:absolute;top:-2.5rem;right:0;background:none;border:none;color:rgba(255,255,255,0.6);font-size:1.8rem;cursor:pointer;transition:color 0.2s;line-height:1;padding:0.25rem}
  .lightbox-close:hover{color:var(--coral)}
  .lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:var(--white);width:48px;height:48px;border-radius:50%;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s;backdrop-filter:blur(4px)}
  .lightbox-nav:hover{background:var(--coral)}
  .lightbox-prev{left:-3.5rem}
  .lightbox-next{right:-3.5rem}
  .lightbox-counter{position:absolute;bottom:-2rem;left:50%;transform:translateX(-50%);font-size:0.78rem;color:rgba(255,255,255,0.4);letter-spacing:0.1em;font-family:'Bebas Neue',sans-serif}
  /* COMING SOON STATE */
  .gallery-coming-soon{text-align:center;padding:5rem 2rem;background:var(--white);border-radius:16px;border:2px dashed var(--cream-dark);margin-top:2rem}
  .gallery-coming-soon p{color:var(--text-light);font-size:1rem;line-height:1.7;max-width:460px;margin:0 auto}
  /* SUBMIT PHOTOS CTA */
  .submit-cta{background:linear-gradient(135deg,var(--plum-deep),var(--plum));padding:5rem 1.5rem;text-align:center;color:var(--white)}
  .submit-cta-inner{max-width:580px;margin:0 auto}
  .submit-cta h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.4rem);font-weight:900;margin-bottom:1rem}
  .submit-cta p{font-size:1.05rem;color:rgba(255,255,255,0.8);margin-bottom:2rem;line-height:1.7}
  /* RESPONSIVE */
  /* Mobile: 0-767px */
  @media(max-width:767px){
    .photo-grid{
      grid-template-columns:1fr 1fr !important;
      gap:0.75rem;
    }
    .photo-item.wide{
      grid-column:span 1;
    }
    .filter-bar{
      padding:0.75rem 1rem;
      overflow-x:auto;
      -webkit-overflow-scrolling:touch;
    }
    .filter-inner{
      flex-wrap:nowrap;
      gap:0.5rem;
    }
    .filter-btn{
      flex-shrink:0;
      font-size:0.8rem;
      padding:0.35rem 0.8rem;
    }
    .lightbox-prev{
      left:-0.5rem;
    }
    .lightbox-next{
      right:-0.5rem;
    }
    .lightbox-nav{
      width:44px;
      height:44px;
      font-size:1.1rem;
    }
    .lightbox-caption{
      font-size:0.85rem;
      margin-top:1rem;
    }
    .submit-cta{
      padding:4rem 1.25rem;
    }
  }
  /* Small Mobile: 0-480px */
  @media(max-width:480px){
    .photo-grid{
      grid-template-columns:1fr 1fr;
      gap:0.5rem;
    }
    .filter-bar{
      padding:0.5rem;
    }
    .filter-btn{
      font-size:0.75rem;
      padding:0.3rem 0.6rem;
    }
    .lightbox{
      padding:1rem;
    }
    .lightbox-caption{
      font-size:0.8rem;
      margin-top:0.75rem;
    }
    .submit-cta{
      padding:3rem 1rem;
    }
    .submit-cta h2{
      font-size:1.6rem;
    }
  }
  /* Tablet: 768-1023px */
  @media(min-width:768px) and (max-width:1023px){
    .photo-grid{
      grid-template-columns:repeat(3,1fr);
      gap:1rem;
    }
    .photo-item.wide{
      grid-column:span 2;
    }
    .submit-cta{
      padding:5rem 2rem;
    }
  }
  /* Large screens: 1024px+ */
  @media(min-width:1024px){
    .submit-cta{
      padding:7rem 3rem;
    }
    .photo-grid{
      grid-template-columns:repeat(4,1fr);
      gap:1.25rem;
    }
    .photo-item.wide{
      grid-column:span 2;
    }
  }
---

<main id="main-content">
<!-- PAGE HERO -->
<header class="page-hero">
  <div class="page-hero-inner">
    <p class="page-label">Campaign Trail</p>
    <h1>On the <em>Ground</em></h1>
    <p>Photos from the trail — town halls, canvasses, and working families across Ohio's 11th District. This campaign belongs to all of us.</p>
  </div>
</header>

<!-- FILTER BAR -->
<div class="filter-bar" role="search" aria-label="Filter photos by category">
  <div class="filter-inner">
    <span class="filter-label">Show:</span>
    <button class="filter-btn active" data-filter="all" aria-pressed="true">All Photos</button>
    <button class="filter-btn" data-filter="trail" aria-pressed="false">Campaign Trail</button>
    <button class="filter-btn" data-filter="community" aria-pressed="false">Community</button>
    <button class="filter-btn" data-filter="events" aria-pressed="false">Events</button>
    <button class="filter-btn" data-filter="cortney" aria-pressed="false">Cortney</button>
  </div>
</div>

<!-- GALLERY -->
<section class="section" aria-labelledby="gallery-heading">
  <div class="section-inner">
    <p class="section-label">Photo Gallery</p>
    <h2 class="section-title" id="gallery-heading">The <em>Campaign</em> in Photos</h2>

    <!--
    ================================================================
    HOW TO ADD PHOTOS:
    1. Place the image in assets/images/gallery/
    2. Strip EXIF data: exiftool -all= yourphoto.jpg
    3. Compress to under 200KB
    4. Copy a <figure class="photo-item"> block below
    5. Set src, alt, data-caption, and data-category
    6. data-category options: trail | community | events | cortney
    7. Add class "tall" for portrait, "wide" for 2-column (desktop)
    ================================================================
    -->

    <div class="photo-grid" id="photoGrid">

      <!-- Existing headshot — using as placeholder until campaign photos arrive -->
      <figure class="photo-item" data-category="cortney"
              data-src="assets/images/cortney-headshot.jpeg"
              data-caption="Cortney Peterson — candidate for Ohio's 11th Congressional District"
              data-category-label="Cortney"
              tabindex="0" role="button" aria-label="View photo: Cortney Peterson official portrait">
        <img src="assets/images/cortney-headshot.jpeg"
             alt="Cortney Peterson, candidate for Congress, official portrait"
             loading="lazy" width="400" height="533">
        <div class="photo-overlay" aria-hidden="true">
          <div class="photo-caption-hover">
            <span>Cortney</span>
            Official Portrait
          </div>
        </div>
      </figure>

      <figure class="photo-item" data-category="cortney"
              data-src="assets/images/CortneyinSnowDec-9-25.jpg"
              data-caption="Cortney Peterson — December 2025, Ohio"
              data-category-label="Cortney"
              tabindex="0" role="button" aria-label="View photo: Cortney Peterson in the snow, December 2025">
        <img src="assets/images/CortneyinSnowDec-9-25.jpg"
             alt="Cortney Peterson smiling on a snowy bridge in Ohio, December 2025"
             loading="lazy" width="400" height="533">
        <div class="photo-overlay" aria-hidden="true">
          <div class="photo-caption-hover">
            <span>Cortney</span>
            Ohio, December 2025
          </div>
        </div>
      </figure>

      <figure class="photo-item wide" data-category="cortney"
              data-src="assets/images/cortney-headshot-wide.jpeg"
              data-caption="Cortney Peterson on the campaign trail in Ohio's 11th District"
              data-category-label="Cortney"
              tabindex="0" role="button" aria-label="View photo: Cortney Peterson wide shot">
        <img src="assets/images/cortney-headshot-wide.jpeg"
             alt="Cortney Peterson, wide campaign photo"
             loading="lazy" width="800" height="600">
        <div class="photo-overlay" aria-hidden="true">
          <div class="photo-caption-hover">
            <span>Campaign Trail</span>
            On the Road for OH-11
          </div>
        </div>
      </figure>

      <!-- Placeholder tiles hidden until campaign photos arrive
      <figure class="photo-item" data-category="trail" tabindex="-1" aria-hidden="true">
        <div class="photo-placeholder">
          <div class="photo-placeholder-icon">📸</div>
          <div class="photo-placeholder-text">Canvass photos<br>coming soon</div>
        </div>
      </figure>

      <figure class="photo-item" data-category="community" tabindex="-1" aria-hidden="true">
        <div class="photo-placeholder">
          <div class="photo-placeholder-icon">🏘</div>
          <div class="photo-placeholder-text">Community event<br>photos coming soon</div>
        </div>
      </figure>

      <figure class="photo-item" data-category="events" tabindex="-1" aria-hidden="true">
        <div class="photo-placeholder">
          <div class="photo-placeholder-icon">🎙</div>
          <div class="photo-placeholder-text">Town hall photos<br>coming soon</div>
        </div>
      </figure>

      <figure class="photo-item" data-category="trail" tabindex="-1" aria-hidden="true">
        <div class="photo-placeholder">
          <div class="photo-placeholder-icon">🚪</div>
          <div class="photo-placeholder-text">Door-knock photos<br>coming soon</div>
        </div>
      </figure>
      -->

    </div><!-- end photoGrid -->

  </div>
</section>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <div class="lightbox-inner">
    <button class="lightbox-close" id="lightboxClose" aria-label="Close photo viewer">&#x2715;</button>
    <button class="lightbox-nav lightbox-prev" id="lightboxPrev" aria-label="Previous photo">&#8249;</button>
    <img class="lightbox-img" id="lightboxImg" src="data:," alt="">
    <button class="lightbox-nav lightbox-next" id="lightboxNext" aria-label="Next photo">&#8250;</button>
    <div class="lightbox-caption" id="lightboxCaption">
      <strong id="lightboxLabel"></strong>
      <span id="lightboxText"></span>
    </div>
    <div class="lightbox-counter" id="lightboxCounter" aria-live="polite"></div>
  </div>
</div>

<!-- SUBMIT PHOTOS CTA -->
<section class="submit-cta" aria-labelledby="submit-heading">
  <div class="submit-cta-inner">
    <p class="page-label" style="color:var(--coral-light)">Share the Moment</p>
    <h2 id="submit-heading">Were You There?</h2>
    <p>If you've got photos from a Cortney event, canvass, or community gathering — send them our way. Real people, real moments. That's the campaign.</p>
    <a href="mailto:cortneyforcongress@gmail.com?subject=Campaign Photos" class="btn btn-coral">Send Us Your Photos</a>
  </div>
</section>

</main>