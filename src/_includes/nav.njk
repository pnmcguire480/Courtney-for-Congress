{% if lang == "es" %}
  {% set navLabels = { about: "Sobre Ella", issues: "Propuestas", platform: "Propuestas", followMoney: "Sigue el Dinero", act: "Participa", getInvolved: "Participa", endorsements: "Apoyos", events: "Eventos", news: "Noticias", updates: "Noticias", gallery: "Galería", press: "Prensa", districtNews: "Noticias del Distrito", vote: "Voto", donate: "Donar" } %}
{% else %}
  {% set navLabels = { about: "About", issues: "Issues", platform: "The Platform", followMoney: "Follow the Money", act: "Act", getInvolved: "Get Involved", endorsements: "Endorsements", events: "Events", news: "News", updates: "Updates", gallery: "Gallery", press: "Press", districtNews: "District News", vote: "Vote", donate: "Donate" } %}
{% endif %}

<!-- ===== NAVIGATION ===== -->
<nav class="nav" id="nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Cortney Peterson — Independent for Congress, OH-11">
      <img src="/assets/images/campaign-logo.png" alt="Cortney Peterson — Independent for Congress, OH-11" width="171" height="104" loading="eager" style="height:52px;width:auto">
    </a>
    <div class="nav-socials">
      {% for social in site.socials %}
      <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ social.label }}"><svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">{{ social.svg | safe }}</svg></a>
      {% endfor %}
    </div>
    <ul class="nav-links" role="list">
      <li><a href="/index.html#meet"{% if navActive == "about" %} class="active"{% endif %}>{{ navLabels.about }}</a></li>
      <li class="nav-dropdown">
        <a href="/issues.html"{% if navActive == "issues" %} class="active"{% endif %}>{{ navLabels.issues }}</a>
        <div class="nav-dropdown-menu">
          <a href="/issues.html"{% if navActive == "issues" %} class="active"{% endif %}>{{ navLabels.platform }}</a>
          <a href="/follow-the-money.html"{% if navActive == "follow-the-money" %} class="active"{% endif %}>{{ navLabels.followMoney }}</a>
        </div>
      </li>
      <li class="nav-dropdown">
        <a href="/get-involved.html"{% if navActive == "act" or navActive == "get-involved" %} class="active"{% endif %}>{{ navLabels.act }}</a>
        <div class="nav-dropdown-menu">
          <a href="/get-involved.html"{% if navActive == "get-involved" %} class="active"{% endif %}>{{ navLabels.getInvolved }}</a>
          <a href="/endorsements.html"{% if navActive == "endorsements" %} class="active"{% endif %}>{{ navLabels.endorsements }}</a>
          <a href="/events.html"{% if navActive == "events" %} class="active"{% endif %}>{{ navLabels.events }}</a>
        </div>
      </li>
      <li class="nav-dropdown">
        <a href="/news/"{% if navActive == "news" %} class="active"{% endif %}>{{ navLabels.news }}</a>
        <div class="nav-dropdown-menu">
          <a href="/news/"{% if navActive == "news" %} class="active"{% endif %}>{{ navLabels.updates }}</a>
          <a href="/gallery.html"{% if navActive == "gallery" %} class="active"{% endif %}>{{ navLabels.gallery }}</a>
          <a href="/press.html"{% if navActive == "press" %} class="active"{% endif %}>{{ navLabels.press }}</a>
          <a href="/district-news.html"{% if navActive == "district-news" %} class="active"{% endif %}>{{ navLabels.districtNews }}</a>
        </div>
      </li>
      <li><a href="/voter-registration.html"{% if navActive == "vote" %} class="active"{% endif %}>{{ navLabels.vote }}</a></li>
      <li><a href="{{ site.donateUrl }}" class="nav-donate" target="_blank" rel="noopener noreferrer">{{ navLabels.donate }}</a></li>
    </ul>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
      <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
    </button>
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu" aria-modal="false">
  <button class="mobile-menu-close" aria-label="Close menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg></button>
  <a href="/index.html#meet">{{ navLabels.about }}</a>
  <a href="/issues.html">{{ navLabels.issues }}</a>
  <a href="/follow-the-money.html">{{ navLabels.followMoney }}</a>
  <a href="/get-involved.html">{{ navLabels.getInvolved }}</a>
  <a href="/endorsements.html">{{ navLabels.endorsements }}</a>
  <a href="/events.html">{{ navLabels.events }}</a>
  <a href="/news/">{{ navLabels.updates }}</a>
  <a href="/gallery.html">{{ navLabels.gallery }}</a>
  <a href="/press.html">{{ navLabels.press }}</a>
  <a href="/voter-registration.html">{{ navLabels.vote }}</a>
  <a href="{{ site.donateUrl }}" class="mobile-donate" target="_blank" rel="noopener noreferrer">{{ navLabels.donate }}</a>
  <div class="nav-socials" style="margin-top:1.5rem">
    {% for social in site.socials %}
    <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ social.label }}"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">{{ social.svg | safe }}</svg></a>
    {% endfor %}
  </div>
  <button class="mobile-theme-toggle" id="mobileThemeToggle" aria-label="Toggle dark mode">
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
    <span class="label-light">Dark Mode</span>
    <span class="label-dark">Light Mode</span>
  </button>
</div>