{% set pct = (site.sigCount / site.sigGoal * 100) | round %}
<!-- SIGNATURE URGENCY BANNER -->
<div class="sig-urgency-banner" role="complementary" aria-label="Signature collection progress">
  <div class="sig-urgency-inner">
    <span class="sig-urgency-count"><strong>{{ site.sigCount | toLocaleString }}</strong> of {{ site.sigGoal | toLocaleString }} signatures</span>
    <div class="sig-urgency-bar"><div class="sig-urgency-fill" style="width:{{ pct }}%"></div></div>
    <span class="sig-urgency-countdown" id="sigCountdown"></span>
    <a href="/get-involved.html" class="sig-urgency-cta">Help Us Get on the Ballot →</a>
  </div>
</div>