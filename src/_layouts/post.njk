---
layout: base
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title | stripHtml }}",
  "datePublished": "{{ date | isoDate }}",
  "author": {
    "@type": "Organization",
    "name": "Cortney Peterson For Congress",
    "url": "https://cortneyforcongress.org/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Cortney Peterson For Congress",
    "url": "https://cortneyforcongress.org/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://cortneyforcongress.org/assets/images/campaign-logo.png"
    }
  },
  "description": "{{ description }}",
  "image": "https://cortneyforcongress.org/assets/images/og-image.png",
  "mainEntityOfPage": "https://cortneyforcongress.org{{ page.url }}"
}
</script>

<header class="post-header">
  <div class="post-header-inner">
    <a href="/news/" class="post-back">All Updates</a>
    <div class="post-tag {{ tagClass }}">{{ tag }}</div>
    <h1>{{ title | safe }}</h1>
    <div class="post-byline">
      <span><strong>{{ author | default("Cortney Peterson for Congress") }}</strong></span>
      <span>{{ date | readableDate }}</span>
      <span>{{ readTime }}</span>
    </div>
  </div>
</header>

<div class="post-body-wrap">
  <article class="post-body" aria-label="Post content">
    {{ content | safe }}

    <div class="post-share" aria-label="Share this article">
      <p class="post-share-label">Share this article</p>
      <div class="post-share-buttons">
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="post-share-btn" aria-label="Share on Facebook">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
        <a href="https://twitter.com/intent/tweet?url={{ site.url }}{{ page.url | urlencode }}&text={{ title | urlencode }}" target="_blank" rel="noopener noreferrer" class="post-share-btn" aria-label="Share on X">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X / Twitter
        </a>
        <a href="https://bsky.app/intent/compose?text={{ title | urlencode }}%20{{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="post-share-btn" aria-label="Share on Bluesky">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.476 6.158 3.228-4.296.678-8.712 2.708-4.87 8.23 4.291 5.395 5.988-1.715 6.088-3.705.1 1.99 1.797 9.1 6.088 3.705 3.842-5.522-.574-7.552-4.87-8.23 2.558.248 5.373-.601 6.158-3.228.246-.828.624-5.788.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.3-1.664-.621-4.3 1.24C8.046 4.747 5.087 8.686 4 10.8"/></svg>
          Bluesky
        </a>
        <a href="https://threads.net/intent/post?text={{ title | urlencode }}%20{{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="post-share-btn" aria-label="Share on Threads">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.59 12c.025 3.086.718 5.496 2.057 7.164 1.432 1.781 3.632 2.695 6.54 2.717 2.227-.017 4.048-.59 5.413-1.703 1.492-1.217 2.094-2.89 2.094-4.178h-.002c0-1.535-.614-2.716-1.824-3.511-1.073-.704-2.476-1.098-4.164-1.17-.12.012-.235.023-.355.032-1.728.14-3.12.671-3.903 1.49-.636.665-.953 1.487-.944 2.443.02 1.956 1.58 3.282 3.88 3.282 1.595 0 2.98-.515 3.793-1.41.552-.608.834-1.377.82-2.236-.009-.595-.188-1.073-.532-1.42-.619-.624-1.776-.93-3.443-.911l-.067-2.12c2.171-.035 3.833.45 4.942 1.44.86.768 1.336 1.79 1.376 2.956.048 1.476-.476 2.83-1.517 3.921-1.2 1.26-2.98 1.97-5.15 2.06l-.32.005c-1.2-.01-2.296-.202-3.276-.572-1.218-.46-2.188-1.19-2.876-2.165-.832-1.178-1.262-2.636-1.28-4.332-.024-1.56.477-2.94 1.49-4.1 1.273-1.46 3.26-2.381 5.59-2.592.22-.02.44-.034.66-.04 2.157-.003 4.047.496 5.617 1.486 1.85 1.165 2.872 2.95 2.872 5.022 0 2.018-.94 4.28-3.072 5.896-1.738 1.318-3.976 2.04-6.656 2.144z"/></svg>
          Threads
        </a>
        <button class="post-share-btn post-share-copy" aria-label="Copy link" onclick="navigator.clipboard.writeText('{{ site.url }}{{ page.url }}').then(function(){this.textContent='Copied!'}.bind(this))">
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          Copy Link
        </button>
      </div>
    </div>

    <nav class="post-nav" aria-label="Post navigation">
      <a href="/news/" class="post-nav-back">All Updates</a>
      {% if nextPost %}<a href="{{ nextPost.url }}" class="post-nav-next">{{ nextPost.title }}</a>{% endif %}
    </nav>
  </article>
</div>

<section class="post-cta" aria-labelledby="post-cta-heading">
  <div class="post-cta-inner">
    <h2 id="post-cta-heading">{{ ctaHeading | default("Ready to Fight for These Changes?") }}</h2>
    <p>{{ ctaText | default("This campaign runs on grassroots power — not PAC money. Every signature, every volunteer, every small donation keeps this movement going.") }}</p>
    <div class="btn-group">
      <a href="/get-involved.html" class="btn btn-coral">Get Involved &rarr;</a>
      <a href="{{ site.donateUrl }}" class="btn btn-ghost" target="_blank" rel="noopener noreferrer">Donate Now</a>
    </div>
  </div>
</section>