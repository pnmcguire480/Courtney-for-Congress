---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <updated>{{ collections.posts[0].date | isoDate }}T00:00:00Z</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>Cortney Peterson for Congress</name>
    <email>{{ site.email }}</email>
  </author>
  {%- for post in collections.posts %}
  <entry>
    <title>{{ post.data.title | stripHtml | replace("&", "&amp;") }}</title>
    <link href="{{ site.url }}{{ post.url }}"/>
    <updated>{{ post.date | isoDate }}T00:00:00Z</updated>
    <id>{{ site.url }}{{ post.url }}</id>
    <summary>{{ post.data.description | replace("&", "&amp;") | replace("<", "&lt;") | replace(">", "&gt;") }}</summary>
  </entry>
  {%- endfor %}
</feed>
