pageStyle: >
  /* FILTER BAR */
  .filter-bar{background:var(--white);border-bottom:1px solid var(--cream-dark);padding:1rem 1.5rem;position:sticky;top:62px;z-index:100}
  .filter-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap}
  .filter-btn{background:var(--cream);color:var(--plum);border:1.5px solid var(--cream-dark);border-radius:8px;padding:0.4rem 1rem;font-size:0.8rem;font-weight:600;cursor:pointer;transition:all 0.2s;white-space:nowrap;min-height:44px;display:inline-flex;align-items:center;gap:0.3rem}
  .filter-btn:hover{border-color:var(--plum-light);background:var(--white)}
  .filter-btn.active{background:var(--plum);color:var(--white);border-color:var(--plum)}
  .filter-count{font-size:0.7rem;opacity:0.7}
  /* NEWS CARDS */
  .news-feed{max-width:800px;margin:0 auto}
  .news-card{display:flex;gap:1rem;padding:1.25rem 0;border-bottom:1px solid var(--cream-dark);transition:background 0.2s}
  .news-card:first-child{padding-top:0}
  .news-card:last-child{border-bottom:none}
  .news-card-body{flex:1;min-width:0}
  .news-card-meta{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.4rem;flex-wrap:wrap}
  .news-source-badge{color:#fff;font-size:0.65rem;font-weight:700;padding:0.15rem 0.5rem;border-radius:4px;text-transform:uppercase;letter-spacing:0.04em;white-space:nowrap}
  .news-category-tag{font-size:0.7rem;font-weight:600;color:var(--plum-light);text-transform:uppercase;letter-spacing:0.06em}
  .news-time{font-size:0.72rem;color:var(--text-light);margin-left:auto}
  .news-card-title{font-family:'Source Sans 3',sans-serif;font-size:1.05rem;font-weight:700;line-height:1.35;margin-bottom:0.3rem}
  .news-card-title a{color:var(--plum);text-decoration:none;transition:color 0.2s}
  .news-card-title a:hover{color:var(--coral)}
  .news-card-excerpt{font-size:0.88rem;color:var(--text-light);line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .news-card-thumb{width:120px;height:80px;border-radius:8px;overflow:hidden;flex-shrink:0}
  .news-card-thumb img{width:100%;height:100%;object-fit:cover}
  /* LOADING & ERROR */
  .news-loading{text-align:center;padding:3rem 1rem;color:var(--text-light)}
  .news-loading-dots{display:inline-flex;gap:0.4rem;margin-top:0.5rem}
  .news-loading-dots span{width:8px;height:8px;background:var(--plum-light);border-radius:50%;animation:loadPulse 1.2s ease-in-out infinite}
  .news-loading-dots span:nth-child(2){animation-delay:0.2s}
  .news-loading-dots span:nth-child(3){animation-delay:0.4s}
  @keyframes loadPulse{0%,80%,100%{opacity:0.3;transform:scale(0.8)}40%{opacity:1;transform:scale(1)}}
  .news-error{text-align:center;padding:2rem;color:var(--text-light);font-size:0.9rem}
  .news-error a{color:var(--coral);font-weight:700}
  .news-source-links{display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;margin-top:1rem}
  .news-source-links a{padding:0.4rem 0.8rem;background:var(--cream);border-radius:6px;color:var(--plum);text-decoration:none;font-size:0.8rem;font-weight:600}
  /* LOAD MORE */
  .load-more-wrap{text-align:center;padding:2rem 0}
  /* DISCLAIMER */
  .news-disclaimer{font-size:0.75rem;color:var(--text-light);text-align:center;padding:0.75rem 1rem;border-top:1px solid var(--cream-dark);margin-top:1rem;font-style:italic}
  /* CTA SECTION */
  .news-cta{background:var(--plum);padding:3rem 1.5rem;text-align:center;color:var(--white)}
  .news-cta-inner{max-width:600px;margin:0 auto}
  .news-cta h2{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,3.5vw,2rem);margin-bottom:0.5rem}
  .news-cta p{color:rgba(255,255,255,0.85);margin-bottom:1.25rem;font-size:1rem}
  /* RESPONSIVE */
  @media(max-width:767px){
    .news-card{flex-direction:column-reverse}
    .news-card-thumb{width:100%;height:160px}
    .news-time{margin-left:0}
    .news-card-meta{gap:0.3rem}
    .filter-bar{top:56px}
  }
  @media(max-width:480px){
    .news-card-title{font-size:0.95rem}
    .news-card-excerpt{font-size:0.82rem;-webkit-line-clamp:3}
  }
