      <a href="/es/voter-registration.html" class="btn" style="background:var(--coral);color:var(--plum);font-weight:700;padding:0.65rem 1.5rem;border-radius:8px;text-decoration:none;display:inline-block;font-size:0.9rem;letter-spacing:0.06em;text-transform:uppercase">Regístrate para Votar →</a>
    </div>
  </div>
</section>

</main>
