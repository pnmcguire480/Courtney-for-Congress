  /* EVENT CARDS */
  .events-grid{display:grid;gap:1.25rem;margin-top:2rem}
  .event-card{background:var(--white);border-radius:16px;border:1.5px solid var(--cream-dark);overflow:hidden;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:0;transition:border-color 0.3s,box-shadow 0.3s}
