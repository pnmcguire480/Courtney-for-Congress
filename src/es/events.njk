    .filter-inner{flex-wrap:nowrap;gap:0.5rem}
    .filter-btn{flex-shrink:0;font-size:0.8rem;padding:0.35rem 0.8rem}
    .events-grid{grid-template-columns:1fr !important}
    .host-cta{padding:4rem 1.25rem}
  }
  @media(max-width:480px){
    .event-card{grid-template-columns:1fr;grid-template-rows:auto}
    .event-date-block{flex-direction:row;gap:0.5rem;align-items:baseline;padding:0.9rem 1.25rem;justify-content:flex-start}
