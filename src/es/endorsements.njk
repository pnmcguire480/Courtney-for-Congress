pageStyle: >
  /* HERO */
  .hero-eyebrow{font-family:'Bebas Neue',sans-serif;font-size:0.85rem;letter-spacing:0.3em;color:var(--coral-light);margin-bottom:1rem;text-transform:uppercase}
  .page-hero h1{font-size:clamp(2.4rem,6vw,4rem)}
  .page-hero p{font-size:1.15rem;max-width:640px;color:rgba(255,255,255,0.85)}
  /* SECTIONS */
  .section{padding:5rem 1.5rem}
  .container{max-width:1100px;margin:0 auto}
  /* CATEGORY LABEL */
  .category-label{font-family:'Bebas Neue',sans-serif;font-size:0.85rem;letter-spacing:0.3em;color:#8a4d3a;text-transform:uppercase;margin-bottom:0.5rem}
  .section-heading{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:700;color:var(--plum);margin-bottom:0.75rem}
  .section-sub{color:var(--text-light);max-width:600px;font-size:1.05rem;line-height:1.7}
  /* ENDORSEMENT GRID */
  .endorsement-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;margin-top:2.5rem}
  .endorsement-card{background:var(--white);border-radius:14px;padding:2rem;box-shadow:0 2px 12px rgba(71,13,68,0.07);border-left:4px solid var(--coral);transition:transform 0.3s ease,box-shadow 0.3s ease}
  .endorsement-card:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(71,13,68,0.12)}
  .endorser-name{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--plum);margin-bottom:0.2rem}
  .endorser-title{font-size:0.85rem;font-weight:600;color:var(--coral);letter-spacing:0.04em;text-transform:uppercase;margin-bottom:1rem}
  .endorser-quote{font-size:0.97rem;color:var(--text-light);line-height:1.7;font-style:italic}
  .endorser-quote::before{content:'"';font-size:1.8rem;color:var(--coral-light);line-height:0;vertical-align:-0.5rem;margin-right:0.2rem}
  .endorser-quote::after{content:'"';font-size:1.8rem;color:var(--coral-light);line-height:0;vertical-align:-0.5rem;margin-left:0.2rem}
  /* ORG ENDORSEMENTS */
  .org-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.25rem;margin-top:2rem}
  .org-card{background:var(--white);border-radius:12px;padding:1.5rem 1.75rem;box-shadow:0 2px 10px rgba(71,13,68,0.06);display:flex;align-items:flex-start;gap:1rem;border-top:3px solid var(--plum-light)}
  .org-featured{grid-column:1/-1;display:grid;grid-template-columns:280px 1fr;gap:2rem;padding:0;overflow:hidden;border-top:none;border:2px solid var(--plum);align-items:stretch}
  .org-featured-img{width:100%;height:100%;object-fit:cover;display:block}
  .org-featured-body{padding:2rem 2rem 2rem 0;display:flex;flex-direction:column;justify-content:center}
  @media(max-width:767px){.org-featured{grid-template-columns:1fr}.org-featured-body{padding:1.5rem}}
  .org-icon{font-size:2rem;flex-shrink:0;line-height:1}
  .org-name{font-weight:700;color:var(--plum);font-size:1rem;line-height:1.3;margin-bottom:0.2rem}
  .org-type{font-size:0.8rem;color:var(--text-light);letter-spacing:0.05em;text-transform:uppercase;font-weight:600}
  /* DIVIDER */
  .section-divider{border:none;border-top:2px solid var(--cream-dark);margin:0}
  /* ENDORSE CTA */
  .endorse-cta{background:var(--cream);color:var(--text);padding:5rem 1.5rem;text-align:center}
  .endorse-cta-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;text-align:left}
  .endorse-cta h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;margin-bottom:1rem;color:var(--plum)}
  .endorse-cta p{font-size:1.1rem;color:var(--text-light);max-width:560px;margin-bottom:1.5rem}
  .endorse-cta-text{margin-bottom:2rem}
  .endorse-pull{font-family:'Playfair Display',serif;font-size:1.2rem;font-style:italic;color:var(--text);border-left:4px solid var(--coral);padding:1.25rem 0 1.25rem 1.5rem;margin-top:2rem;line-height:1.6;text-align:left;display:block}
  .endorse-pull cite{display:block;font-style:normal;font-size:0.85rem;color:var(--plum-light);margin-top:0.75rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase}
  .endorse-form-wrap{max-width:540px;margin:0 auto;border:1px solid rgba(71,13,68,0.1);border-radius:16px;padding:2.5rem;background:var(--white)}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
  .form-group{display:flex;flex-direction:column;gap:0.4rem;margin-bottom:1rem}
  .form-group label{font-size:0.85rem;font-weight:600;letter-spacing:0.05em;color:var(--plum);text-transform:uppercase}
  .form-group input,.form-group textarea,.form-group select{width:100%;padding:0.85rem 1rem;border-radius:8px;border:1.5px solid rgba(71,13,68,0.15);background:var(--cream);color:var(--text);font-size:1rem;font-family:'Source Sans 3',sans-serif;transition:border-color 0.3s}
  .form-group input::placeholder,.form-group textarea::placeholder{color:var(--text-light)}
  .form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--plum)}
  .form-group select option{color:var(--text);background:var(--cream)}
  .form-group textarea{resize:vertical;min-height:110px}
  .btn-submit{width:100%;padding:1rem;background:var(--plum);color:var(--cream);font-size:1.05rem;font-weight:700;letter-spacing:0.06em;border:none;border-radius:10px;cursor:pointer;transition:background 0.3s,transform 0.2s;font-family:'Source Sans 3',sans-serif;margin-top:0.5rem}
  .btn-submit:hover{background:var(--plum-light);transform:translateY(-1px)}
  .endorse-success{display:none;text-align:center;padding:2rem}
  .endorse-success .check{font-size:3rem;margin-bottom:1rem}
  .endorse-success h3{font-family:'Playfair Display',serif;font-size:1.6rem;margin-bottom:0.75rem;color:var(--plum)}
  .endorse-success p{color:var(--text)}
  /* RESPONSIVE */
  @media(max-width:767px){
    .endorsement-grid{grid-template-columns:1fr !important}
    .org-grid{grid-template-columns:1fr !important}
    .form-row{grid-template-columns:1fr !important}
    .endorse-cta-inner{grid-template-columns:1fr !important;gap:2rem}
    .org-featured{grid-template-columns:1fr !important}
    .org-featured-body{padding:1.5rem !important}
    .section{padding:4rem 1.25rem}
    .endorse-form-wrap{padding:2rem 1.5rem;border-radius:12px}
    .endorse-cta{padding:4rem 1.25rem;text-align:center}
    .endorse-cta h2{font-size:clamp(1.6rem,5vw,2.2rem)}
    .endorse-pull{text-align:center;border-left:none;padding-left:0}
  }
  @media(max-width:480px){
    .section{padding:3rem 1rem}
    .endorsement-card{padding:1.75rem 1.5rem}
    .org-card{padding:1.25rem 1.5rem}
    .endorse-form-wrap{padding:1.75rem 1.25rem}
    .endorse-cta{padding:3rem 1rem}
    .endorse-pull{padding:1rem 0 1rem 1.25rem;font-size:1.1rem}
  }
  @media(min-width:768px) and (max-width:1023px){
    .section{padding:5rem 2rem}
    .endorsement-grid{grid-template-columns:repeat(2,1fr)}
    .org-grid{grid-template-columns:repeat(2,1fr)}
