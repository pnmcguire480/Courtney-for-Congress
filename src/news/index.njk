layout: base
title: "Campaign Updates | Cortney Peterson for Congress — OH-11"
description: "Latest news, statements, and updates from Cortney Peterson's grassroots campaign for Ohio's 11th Congressional District."
ogTitle: "Campaign Updates | Cortney Peterson for Congress"
ogDescription: "Latest news, statements, and updates from Cortney Peterson's grassroots campaign for Ohio's 11th."
ogUrl: "https://cortneyforcongress.org/news/"
navActive: "news"
pageScripts: []
permalink: /news/index.html
hreflang:
  - lang: en
    url: https://cortneyforcongress.org/news/
  - lang: x-default
    url: https://cortneyforcongress.org/news/
ldJson: >
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Campaign Updates",
    "description": "Latest news and updates from Cortney Peterson's campaign for Ohio's 11th Congressional District.",
    "url": "https://cortneyforcongress.org/news/",
    "image": "https://cortneyforcongress.org/assets/images/og-image.png",
    "publisher": {
      "@type": "Organization",
      "name": "Cortney Peterson For Congress",
      "url": "https://cortneyforcongress.org/"
    }
  }
pageStyle: >
  .posts-section{padding:4.5rem 1.5rem}
  .posts-inner{max-width:1100px;margin:0 auto}
  .posts-grid{display:grid;gap:2rem;margin-top:2.5rem}
  .post-card{background:var(--white);border-radius:16px;border:1.5px solid var(--cream-dark);overflow:hidden;transition:border-color 0.3s,box-shadow 0.3s;display:flex;flex-direction:column}
  .post-card:hover{border-color:var(--coral);box-shadow:0 6px 32px rgba(71,13,68,0.09)}
  .post-card-body{padding:2rem;flex:1;display:flex;flex-direction:column}
  .post-meta{display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap}
  .post-date{font-family:'Bebas Neue',sans-serif;font-size:0.78rem;letter-spacing:0.2em;color:#a0604a;text-transform:uppercase}
  .post-tag{font-size:0.72rem;font-weight:700;letter-spacing:0.1em;padding:0.2rem 0.65rem;border-radius:4px;text-transform:uppercase}
  .tag-update{background:#e8eaf6;color:#3949ab}
  .tag-statement{background:#fce4ec;color:#ad1457}
  .tag-event-recap{background:#e8f4e8;color:#2d6a2d}
  .tag-press{background:#fff3e0;color:#a05000}
  .post-title{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:900;color:var(--plum);line-height:1.25;margin-bottom:0.75rem}
  .post-title a{color:inherit;text-decoration:none;transition:color 0.25s}
  .post-title a:hover{color:var(--coral)}
  .post-excerpt{font-size:0.95rem;color:var(--text-light);line-height:1.75;flex:1}
  .post-read-more{display:inline-flex;align-items:center;gap:0.4rem;margin-top:1.5rem;font-weight:700;font-size:0.85rem;color:var(--plum);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;transition:color 0.25s}
  .post-read-more:hover{color:var(--coral)}
  .post-read-more::after{content:'→';transition:transform 0.25s}
  .post-read-more:hover::after{transform:translateX(3px)}
  .post-card.featured{border-color:var(--plum);border-width:2px}
  .post-card.featured .post-title{font-size:1.7rem}
  .featured-label{font-family:'Bebas Neue',sans-serif;font-size:0.75rem;letter-spacing:0.25em;color:var(--white);background:var(--plum);padding:0.3rem 0.8rem;text-transform:uppercase;display:inline-block;margin-bottom:1rem}
  .no-posts{text-align:center;padding:5rem 2rem;background:var(--white);border-radius:16px;border:2px dashed var(--cream-dark)}
  .no-posts p{color:var(--text-light);font-size:1rem;line-height:1.7;max-width:420px;margin:0 auto}
  .news-cta{background:linear-gradient(135deg,var(--plum-deep),var(--plum));padding:5rem 1.5rem;text-align:center;color:var(--white)}
  .news-cta-inner{max-width:580px;margin:0 auto}
  .news-cta h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.4rem);font-weight:900;margin-bottom:1rem}
  .news-cta p{font-size:1.05rem;color:rgba(255,255,255,0.8);margin-bottom:2rem;line-height:1.7}
  .signup-inline{display:flex;gap:0.6rem;max-width:420px;margin:0 auto;flex-wrap:wrap}
  .signup-inline input{flex:1;min-width:200px;padding:0.85rem 1rem;border-radius:10px;border:1.5px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.1);color:var(--white);font-size:0.95rem;font-family:'Source Sans 3',sans-serif}
  .signup-inline input::placeholder{color:rgba(255,255,255,0.45)}
  .signup-inline input:focus{outline:none;border-color:var(--coral)}
  .signup-inline button{padding:0.85rem 1.5rem;background:var(--plum);border:none;border-radius:10px;color:var(--white);font-weight:700;font-size:0.88rem;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;transition:background 0.25s;font-family:'Source Sans 3',sans-serif;white-space:nowrap}
  .signup-inline button:hover{background:var(--coral-light)}
  @media(max-width:480px){
    .posts-section{padding:3.5rem 1.25rem}
  }
  @media(min-width:1024px){
    .posts-section{padding:6rem 3rem}
    .posts-grid{grid-template-columns:1fr 1fr;align-items:start}
    .post-card.featured{grid-column:span 2}
    .news-cta{padding:7rem 3rem}
  }
  @media(max-height:500px) and (orientation:landscape){
    .posts-section{padding:3rem 1.5rem}
    .news-cta{padding:3rem 1.5rem}
  }
---

<main id="main-content">
<!-- PAGE HERO -->
<header class="page-hero">
  <div class="page-hero-inner">
    <p class="page-label">From the Campaign</p>
    <h1>Campaign <em>Updates</em></h1>
    <p>Statements, event recaps, and news from Cortney's campaign for Ohio's 11th Congressional District.</p>
  </div>
</header>

<!-- POSTS LISTING -->
<section class="posts-section" aria-labelledby="posts-heading">
  <div class="posts-inner">
    <p style="font-family:'Bebas Neue',sans-serif;font-size:0.85rem;letter-spacing:0.3em;color:#a0604a;text-transform:uppercase;margin-bottom:0.6rem">Latest</p>
    <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.4rem);font-weight:900;color:var(--plum);margin-bottom:0;line-height:1.15" id="posts-heading">What's <em style="font-style:italic;color:var(--coral)">Happening</em></h2>

    <div class="posts-grid" id="postsGrid">
      {% for post in collections.posts %}
      <article class="post-card{% if loop.first %} featured{% endif %} reveal">
        <div class="post-card-body">
          {% if loop.first %}<span class="featured-label">Latest Update</span>{% endif %}
          <div class="post-meta">
            <span class="post-date">{{ post.date | shortDate }}</span>
            <span class="post-tag {{ post.data.tagClass }}">{{ post.data.tag }}</span>
          </div>
          <h3 class="post-title"><a href="{{ post.url }}">{{ post.data.title | safe }}</a></h3>
          <p class="post-excerpt">{{ post.data.description }}</p>
          <a href="{{ post.url }}" class="post-read-more" aria-label="Read full post: {{ post.data.title }}">Read More</a>
        </div>
      </article>
      {% endfor %}

      {% if collections.posts.length == 0 %}
      <div class="no-posts">
        <p>No updates yet. Check back soon for campaign news, statements, and event recaps.</p>
      </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- EMAIL SIGNUP CTA -->
<section class="news-cta" aria-labelledby="news-cta-heading">
  <div class="news-cta-inner">
    <p style="font-family:'Bebas Neue',sans-serif;font-size:0.85rem;letter-spacing:0.3em;color:var(--plum-light);text-transform:uppercase;margin-bottom:0.75rem">Never Miss an Update</p>
    <h2 id="news-cta-heading">Get Updates in Your Inbox</h2>
    <p>Campaign news, event announcements, and statements — delivered directly to you. No spam. Unsubscribe any time.</p>
    <form class="signup-inline signup-form" name="email-signup" method="POST" action="/success.html" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="email-signup">
      <p hidden><label>Don't fill this out: <input name="bot-field"></label></p>
      <input type="email" name="email" placeholder="Your email address" aria-label="Email address" autocomplete="email" required>
      <button type="submit">Sign Up</button>
    </form>
  </div>
</section>

</main>